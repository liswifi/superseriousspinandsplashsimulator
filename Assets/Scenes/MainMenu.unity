  m_Script: {fileID: 11500000, guid: f50b9c5f073786e4a9c972b663240e7a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  guiText: {fileID: 1241470634}
  textRaw: Good morning viewers! Are you ready to spin and splash Presidential style? 
    For those new to the course, we do this for one reason - to determine who will
    become president, based on how well they can overcome adversity... that is, by
    getting really god damn dizzy and doing an obstacle course!  So, this is how
    it works! You have to get to the end of the course, but you get extra points
    based on your level of dizziness! Don't fall off, or no Presidential power for
    you!   Joking, you can try again. But we will also laugh and make fun of you
    for being bad. So do your best!  Our best contestant will win the grand prize
    of becoming The President! That's right, that one! So get your score as high
    as possible and prove you have what it takes to be That Guy.  So without further
    ado... lets get spin splashed president elects!
  textList: []
  textIndex: 0
  textBox: {fileID: 1220195134}
  iconboxNext: {fileID: 418529415}
  iconboxEnd: {fileID: 1283656509}
